local function SpawnKillFX(effectName, folderName, victimCharacter)
    if not effectName or not folderName or not victimCharacter then return end
    if not KillFxFolder then return end
    local folder = KillFxFolder:FindFirstChild(folderName)
    if not folder then return end
    local fx = folder:FindFirstChild(effectName)
    if not fx then return end
    local hrp = victimCharacter:FindFirstChild("HumanoidRootPart") or victimCharacter:FindFirstChild("UpperTorso") or victimCharacter:FindFirstChild("Torso")
    if not hrp then return end
    local clone = fx:Clone()
    clone.Parent = workspace
    if clone:IsA("Model") then
        if clone.PrimaryPart then
            local ok, err = pcall(function() clone:SetPrimaryPartCFrame(hrp.CFrame) end)
            if not ok then
                for _, part in ipairs(clone:GetDescendants()) do
                    if part:IsA("BasePart") then part.CFrame = hrp.CFrame end
                end
            end
        else
            for _, part in ipairs(clone:GetDescendants()) do
                if part:IsA("BasePart") then part.CFrame = hrp.CFrame end
            end
        end
    elseif clone:IsA("BasePart") then
        clone.CFrame = hrp.CFrame
    end
    local sounds = {}
    local connections = {}
    for _, obj in ipairs(clone:GetDescendants()) do
        if obj:IsA("ParticleEmitter") then
            pcall(function() obj.Enabled = true end)
            local emitCount = obj:GetAttribute("EmitCount")
            if type(emitCount) == "number" and emitCount > 0 then
                pcall(function() obj:Emit(emitCount) end)
            else
                pcall(function() obj:Emit(30) end)
            end
        elseif obj:IsA("Beam") then
            pcall(function() obj.Enabled = true end)
            if not obj.Attachment0 or not obj.Attachment1 then
                local a0 = Instance.new("Attachment", clone)
                local a1 = Instance.new("Attachment", clone)
                a0.Position = Vector3.new(0,0,0)
                a1.Position = Vector3.new(0,0,0)
                obj.Attachment0 = a0
                obj.Attachment1 = a1
            end
        elseif obj:IsA("Trail") then
            pcall(function() obj.Enabled = true end)
        elseif obj:IsA("Sound") then
            local s = obj
            pcall(function() s:Play() end)
            table.insert(sounds, s)
        else
            pcall(function() if obj.Enabled ~= nil then obj.Enabled = true end end)
        end
    end
    local cleaned = false
    local function doCleanup()
        if cleaned then return end
        cleaned = true
        for _, s in ipairs(sounds) do pcall(function() s:Stop() end) end
        for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
        safeDestroy(clone)
    end
    local cleanupTimer = task.delay(5, doCleanup)
    local humanoid = victimCharacter:FindFirstChild("Humanoid")
    local diedConn
    if humanoid then
        diedConn = humanoid.Died:Connect(function()
            doCleanup()
            if diedConn then diedConn:Disconnect() end
        end)
        table.insert(connections, diedConn)
    end
    local ancestryConn
    ancestryConn = victimCharacter.AncestryChanged:Connect(function()
        if not victimCharacter:IsDescendantOf(game) then
            doCleanup()
            if ancestryConn then ancestryConn:Disconnect() end
        end
    end)
    table.insert(connections, ancestryConn)
    Debris:AddItem(clone, 5)
end
