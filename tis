local lastTrail = nil
local function hookKillFxTrail(gunName)
    if not KillFxFolder then return end
    local gunFx = KillFxFolder:FindFirstChild(gunName)
    if not gunFx then return end
    if lastTrail and lastTrail.Parent then lastTrail:Destroy() lastTrail = nil end
    local trails = {}
    for _, obj in ipairs(gunFx:GetDescendants()) do
        if obj:IsA("Trail") then table.insert(trails, obj) end
    end
    if #trails == 0 then return end
    local sourceTrail = trails[math.random(1, #trails)]
    local newTrail = sourceTrail:Clone()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
    if not hand then return end
    local att0 = hand:FindFirstChild("TrailAttachment0") or Instance.new("Attachment", hand)
    att0.Name = "TrailAttachment0"
    att0.Position = Vector3.new(0,0.5,0)
    local att1 = hand:FindFirstChild("TrailAttachment1") or Instance.new("Attachment", hand)
    att1.Name = "TrailAttachment1"
    att1.Position = Vector3.new(0,-0.5,0)
    newTrail.Attachment0 = att0
    newTrail.Attachment1 = att1
    newTrail.Parent = hand
    newTrail.Enabled = true
    lastTrail = newTrail
end
