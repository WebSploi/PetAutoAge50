local WHITELIST_URL = "https://raw.githubusercontent.com/WebSploi/EggSpawner/main/wl"

local function CheckWhitelist()
    local success, result = pcall(function()
        return HttpService:GetAsync(WHITELIST_URL)
    end)

    if not success then
        warn("Whitelist fetch failed")
        LocalPlayer:Kick("Whitelist check failed.")
        return false
    end

    local allowed = false
    for name in string.gmatch(result, "[^\r\n]+") do
        if string.lower(name) == string.lower(LocalPlayer.Name) then
            allowed = true
            break
        end
    end

    if not allowed then
        LocalPlayer:Kick("You are not whitelisted to use this script.")
        return false
    end

    return true
end

if not CheckWhitelist() then
    return
end

