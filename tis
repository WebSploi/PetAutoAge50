local TargetGuns = {"Pistol","Pistol .50","Combat_P","SP"}
local SelectedSound = "Beesaya"
local function ApplySoundToGun(gun)
    if not gun or not gun:IsA("Tool") then return end
    local soundsFolder = gun:FindFirstChild("Sounds")
    if not soundsFolder then return end
    local shootMain = soundsFolder:FindFirstChild("Shoot")
    local shoot1, shoot2, shoot3
    if shootMain then
        shoot1 = shootMain:FindFirstChild("Shoot1")
        shoot2 = shootMain:FindFirstChild("Shoot2")
        shoot3 = shootMain:FindFirstChild("Shoot3")
    end
    if shootMain and shootMain:IsA("Sound") then
        shootMain.SoundId = GunSounds[SelectedSound]
    end
    if shoot1 and shoot1:IsA("Sound") then
        shoot1.SoundId = GunSounds[SelectedSound]
    end
    if shoot2 and shoot2:IsA("Sound") then
        shoot2.SoundId = GunSounds[SelectedSound]
    end
    if shoot3 and shoot3:IsA("Sound") then
        shoot3.SoundId = GunSounds[SelectedSound]
    end
end
local function ApplyToCharacter()
    local charactersFolder = workspace:FindFirstChild("Characters")
    if not charactersFolder then return end
    local character = charactersFolder:FindFirstChild(LocalPlayer.Name)
    if not character then return end
    for _, gunName in ipairs(TargetGuns) do
        local gun = character:FindFirstChild(gunName)
        if gun then
            ApplySoundToGun(gun)
        end
    end
end
local Options = {}
for name,_ in pairs(GunSounds) do
    table.insert(Options, name)
end
table.sort(Options)
GunSoundGroup:Dropdown({
    Name = "Select Gun Sound",
    Options = Options,
    Default = SelectedSound,
    Callback = function(option)
        SelectedSound = option
        ApplyToCharacter()
        Library:Notify("Gun Sound Selected: " .. SelectedSound)
    end
})
