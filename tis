local function WallCheck(part)
    local origin = Camera.CFrame.Position
    local dir = (part.Position - origin)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    params.FilterType = Enum.RaycastFilterType.Blacklist
    local result = workspace:Raycast(origin, dir, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end
local function GetTarget()
    local closest, shortest = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local char = player.Character
            if IsRedHighlighted(player) then continue end
            if game:GetService("CollectionService"):HasTag(char, "Ragdoll") then continue end
            -- DeadCheck + TeamCheck functions completely removed (toggles still exist in menu but do nothing)
            local part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            if part and WallCheck(part) then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                local dist = (Vector2.new(screenPos.X,screenPos.Y)-Camera.ViewportSize/2).Magnitude
                if onScreen and dist < Settings.Aimbot.FOV and dist < shortest then
                    closest, shortest = part, dist
                end
            end
        end
    end
    return closest
end
